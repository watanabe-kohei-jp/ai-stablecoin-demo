# ===== これは雛形です。コピーして .env を作り、実値を入れてください =====
# cp .env.example .env  （PowerShell: Copy-Item .env.example .env）
#
# .env は .gitignore 済み。秘密鍵をGitHubに上げない安全装置です。

# --- 買い手エージェントのテスト用ウォレット（Phase 1 で自動生成） ---
AGENT_PRIVATE_KEY=0xあなたのテスト用秘密鍵（使い捨て・本物の資金を入れない）
AGENT_ADDRESS=0xあなたのテスト用アドレス

# --- 売り手（受取）アドレス。Phase 1 で2つ目を生成 or 同じでも可 ---
VENDOR_ADDRESS=0x売り手の受取アドレス

# --- ネットワーク設定（Base Sepolia テストネット） ---
NETWORK=base-sepolia
CHAIN_ID=84532
# Base Sepolia の公式テストUSDC（decimals=6）
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# テストネット用 facilitator（無認証で使えるもの。Phase 2 で確定）
FACILITATOR_URL=https://x402.org/facilitator

# --- RPC（残高確認・Vault操作用。公開エンドポイントでOK。※read-after-write遅延あり） ---
RPC_URL=https://sepolia.base.org

# ===== 自動スイープ（模擬利回りVault）。任意。未設定なら従来どおり vault 無効で動く =====
# ⚠️ MockYieldVault はテストネット専用の「利回り模擬」で本物のRWA/MMFではない。
# scripts/deploy_vault.py --deploy でデプロイすると VAULT_ADDRESS が自動で書き込まれる。
VAULT_ADDRESS=0x（deploy_vault.py --deploy で自動設定）
# Vault のデプロイ時 APY（年率bps）。500=5%。デモで利回りを見せたいなら大きめにしてもよい
VAULT_APY_BPS=500
# 手元に常に残す運転資金（USDC）。スイープはこれを超える余剰だけ Vault へ預ける
TREASURY_MIN_USDC=0.01

# ===== 流動性の階段（3層：SC ⇄ 預金Vault ⇄ ST）。任意。未設定なら1層のまま =====
# ⚠️ どちらもテストネット専用の模擬。scripts/deploy_ladder.py --deploy-deposit --deploy-st
#    でデプロイすると下記2つが自動で書き込まれる。
# 即時層＝模擬トークン化預金（MockYieldVault を低APYで流用・即時償還）
DEPOSIT_VAULT_ADDRESS=0x（deploy_ladder.py --deploy-deposit で自動設定）
DEPOSIT_APY_BPS=100
# 遅延層＝模擬ST（MockSecurityToken・高APY・二段階償還＝償還ラグあり）
ST_ADDRESS=0x（deploy_ladder.py --deploy-st で自動設定）
ST_APY_BPS=800
# 償還ラグ（秒）。本物のRWAの T+N を短時間で模擬する
ST_REDEEM_DELAY_SEC=120

# ===== Phase 5：LLM頭脳（御三家比較）。キーを入れた社だけ実際に動く =====
# どれも任意。未設定の社は自動でスキップ（全社未設定なら rule_based に降格）。
# これらは「実費（少額の本物の課金）」が発生する点に注意（テストネットとは別枠）。

# Claude（Anthropic）: https://console.anthropic.com/ で発行
ANTHROPIC_API_KEY=
# GPT（OpenAI）: https://platform.openai.com/api-keys で発行
OPENAI_API_KEY=
# Gemini（Google）: https://aistudio.google.com/apikey で発行
GEMINI_API_KEY=

# --- 使用モデル（任意。未設定なら経済ティアの既定を使用） ---
# 旗艦同士で比較したいときはここを書き換える（例: claude-sonnet-4-6 / gpt-4.1 / gemini-2.5-pro）
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash
